# .gitignore for IBS Microbiome Analysis Repository

# -----------------------------------------------
# macOS system files
# -----------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------
# Large data files (submit via data repository)
# -----------------------------------------------
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.sam
*.bz2

# -----------------------------------------------
# Intermediate / output files
# -----------------------------------------------
*.log
*.tmp
*.bak

# Output PDFs generated by scripts (reproducible from code)
confusion_matrix_loocv.pdf
binary_roc_curve_loocv.pdf
all-samples-pcoa.pdf

# -----------------------------------------------
# R session artefacts
# -----------------------------------------------
.Rhistory
.RData
.Rproj.user/
*.Rproj

# -----------------------------------------------
# Python artefacts
# -----------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# -----------------------------------------------
# Jupyter
# -----------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------
# Editor / IDE
# -----------------------------------------------
.vscode/
.idea/
*.swp
*~
